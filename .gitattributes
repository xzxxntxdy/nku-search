# Normalize text files for consistent diffs across Windows/macOS/Linux.
* text=auto eol=lf

# Windows command scripts are usually edited and executed on Windows.
*.bat text eol=crlf
*.cmd text eol=crlf

# Source and documentation.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Binary artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.zip binary
*.rar binary
*.7z binary
*.db binary
*.sqlite binary
*.sqlite3 binary
